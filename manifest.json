{
  "manifest_version": 3,
  "name": "ChromeKontrol",
  "version": "2.0.0",
  "description": "WebSocket経由でDOMアクセスと要素操作を行う軽量Chrome拡張機能。",

  "permissions": [
    "activeTab",
    "alarms",
    "scripting",
    "storage"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "host_permissions": [
    "<all_urls>"
  ]
}
